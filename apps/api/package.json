{
  "name": "@gitvisor/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --env-file ../../../.env.local --watch dist/index.js",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@gitvisor/auth": "workspace:*",
    "@gitvisor/db": "workspace:*",
    "@gitvisor/github": "workspace:*",
    "@gitvisor/queue": "workspace:*",
    "@gitvisor/shared": "workspace:*",
    "@hono/node-server": "^1.14.3",
    "hono": "^4.7.10",
    "libsodium-wrappers": "^0.7.16"
  },
  "devDependencies": {
    "@types/libsodium-wrappers": "^0.7.14",
    "@types/node": "^22.15.17",
    "typescript": "^5.8.3"
  }
}
